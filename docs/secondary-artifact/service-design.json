    {
      "name": "QuotaService",
      "description": "Plan limits & usage tracking",
      "responsibilities": [
        "check limits",
        "increment usage"
      ],
      "dependencies": [
        "prisma"
      ],
      "methods": []
    }
  ],
  "layers": {
    "controllers": [
      "Express routers under backend/src/routes/* validate input (zod) and delegate to services"
    ],
    "services": [
      "Business logic & cross-cutting (quota, queue dispatch) under backend/src/services/*"
    ],
    "repositories": [
      "Prisma client acts as the repository layer; no separate repository folder"
    ]
  }
}