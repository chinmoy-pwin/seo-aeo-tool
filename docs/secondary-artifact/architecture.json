{
  "pattern": "monolith",
  "diagram": "[React SPA] --HTTP--> [Express API] --SQL--> [PostgreSQL]\n                              |\n                              +--enqueue--> [BullMQ/Redis] --process--> [Workers] --> [PostgreSQL]",
  "dataFlow": [
    "1: User opens SPA, which calls /api/dashboard/summary with x-workspace-id header",
    "2: API aggregates per-workspace stats via Prisma and returns JSON",
    "3: Write endpoints (e.g. create index job) persist a record and enqueue background work",
    "4: Workers process jobs, update DB rows, and emit alerts/quota updates",
    "5: SPA refetches list/detail endpoints to show updated state"
  ],
  "routeAccess": {
    "authEnabled": false,
    "includeLandingPage": false,
    "signupPath": "/signup",
    "defaultAuthenticatedHome": "/dashboard",
    "pages": [
      {
        "path": "/",
        "component": "DashboardPage",
        "access": "public",
        "reason": "Demo dashboard home"
      },
      {
        "path": "/sites",
        "component": "SitesPage",
        "access": "public",
        "reason": "Site management"
      },
      {
        "path": "/indexing",
        "component": "IndexingPage",
        "access": "public",
        "reason": "Index jobs"
      },
      {
        "path": "/audits",
        "component": "AuditsPage",
        "access": "public",
        "reason": "Audit reports"
      },
      {
        "path": "/keywords",
        "component": "KeywordsPage",
        "access": "public",
        "reason": "Rank tracking"
      },
      {
        "path": "/backlinks",
        "component": "BacklinksPage",
        "access": "public",
        "reason": "Backlink monitor"
      },
      {
        "path": "/content",
        "component": "ContentDraftPage",
        "access": "public",
        "reason": "AI content drafts"
      },
      {
        "path": "/ai-monitoring",
        "component": "AiMonitoringPage",
        "access": "public",
        "reason": "Brand prompt monitor"
      },
      {
        "path": "/integrations",
        "component": "IntegrationsPage",
        "access": "public",
        "reason": "WP connections"
      },
      {
        "path": "/alerts",
        "component": "AlertsPage",
        "access": "public",
        "reason": "Alerts feed"
      }
    ],
    "apiRoutes": [
      {
        "method": "GET",
        "path": "/api/health",
        "access": "public"
      },
      {
        "method": "GET",
        "path": "/api/workspaces",
        "access": "public",
        "reason": "api contract"
      },
      {
        "method": "GET",
        "path": "/api/sites",
        "access": "public",
        "reason": "api contract"
      },
      {
        "method": "GET",
        "path": "/api/index-jobs",
        "access": "public",
        "reason": "api contract"
      },
      {
        "method": "GET",
        "path": "/api/audits",
        "access": "public",
        "reason": "api contract"
      },
      {
        "method": "GET",
        "path": "/api/keywords",
        "access": "public",
        "reason": "api contract"
      },
      {
        "method": "GET",
        "path": "/api/backlinks",
        "access": "public",
        "reason": "api contract"
      },
      {
        "method": "GET",
        "path": "/api/content-drafts",
        "access": "public",
        "reason": "api contract"
      },
      {
        "method": "GET",
        "path": "/api/brand-prompts",
        "access": "public",
        "reason": "api contract"
      },
      {
        "method": "GET",
